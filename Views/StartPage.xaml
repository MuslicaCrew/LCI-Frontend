<Page x:Class="LungCancerIdentifierFrontEnd.Views.StartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource AppBackgroundBrush}">

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Back button row -->
            <RowDefinition Height="*"/>      <!-- Content -->
        </Grid.RowDefinitions>

     
        <Button Grid.Row="0"
                Content="← Back"
                Style="{StaticResource BackButton}"
                HorizontalAlignment="Left"
                Click="Back_Click"/>

        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <TextBlock Text="Open a DICOM file for scanning"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="{StaticResource ForegroundBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <TextBlock Text="Click the button below to browse for a file on your system."
                       FontSize="14"
                       Foreground="#AAAAAA"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <!-- Open File Button -->
            <Button Content="📂  Browse File"
                    Style="{StaticResource OpenFileButton}"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,20"
                    Click="OpenFile_Click"/>

            <!-- File path display box -->
            <Border Background="{StaticResource ButtonBackgroundBrush}"
                    CornerRadius="8"
                    Padding="16"
                    MinWidth="420"
                    MinHeight="56"
                    VerticalAlignment="Center">
                <TextBlock x:Name="FilePathText"
                           Text="No file selected."
                           Foreground="#AAAAAA"
                           FontSize="13"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
            </Border>

        </StackPanel>
    </Grid>
</Page>
